{
  "name": "@coding-report/root",
  "version": "0.0.1",
  "description": "report-engine",
  "main": "index.js",
  "scripts": {
    "build:report-univer": "pnpm -F @coding-report/report-univer build",
    "build:report-api": "pnpm -F @coding-report/report-api build",
    "build:report-engine": "pnpm -F @coding-report/report-engine build",
    "build": "pnpm run build:report-univer && pnpm run build:report-api && pnpm run build:report-engine",
    "watch:report-engine": "pnpm -F @coding-report/report-engine dev",
    "watch:report-univer": "pnpm -F @coding-report/report-univer dev",
    "watch:report-api": "pnpm -F @coding-report/report-api dev",
    "push:report-engine": "pnpm -F @coding-report/report-engine push",
    "push:report-univer": "pnpm -F @coding-report/report-univer push",
    "push": "pnpm run push:report-univer && pnpm run push:report-engine",
    "dev:app-pc": "pnpm -F @report-example/app-pc dev",
    "dev": "pnpm run dev:app-pc",
    "lint": "rslint",
    "lint:fix": "rslint --fix",
    "clean": "pnpm cleaninstall-node"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@rsbuild/plugin-react": "^1.4.5",
    "@rslib/core": "^0.20.0",
    "@rslint/core": "^0.6.1",
    "@rstest/adapter-rslib": "^0.2.1",
    "@rstest/core": "^0.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "cleaninstall-node": "^2.2.3",
    "happy-dom": "^20.8.3",
    "typescript": "^5.9.3"
  }
}
